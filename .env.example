# INVCRIPTO IA - exemplo seguro para GitHub
# Não coloque chaves reais neste arquivo.

VITE_APP_NAME=INVCRIPTO IA
VITE_APP_URL=https://invcripto.netlify.app
VITE_PASSWORD_RESET_URL=https://invcripto.netlify.app/reset-password

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=COLE_SUA_ANON_KEY_SOMENTE_NO_NETLIFY

SUPABASE_PROJECT_ID=SEU_PROJECT_ID
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=COLE_SUA_ANON_KEY_SOMENTE_NO_NETLIFY
SUPABASE_SERVICE_ROLE_KEY=COLE_SUA_SERVICE_ROLE_SOMENTE_NO_NETLIFY
APP_ENCRYPTION_KEY=troque-por-uma-chave-forte-com-32-ou-mais-caracteres

BOT_DEFAULT_MODE=paper
BOT_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,AVAXUSDT,DOGEUSDT,LINKUSDT,DOTUSDT,LTCUSDT,TRXUSDT
