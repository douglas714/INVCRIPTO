BOT_TIMEFRAME=5m

ENV_INITIAL_BALANCE=10
ENV_FEE_PERCENT=10
ENV_CURRENCY_USD_VALUE=1
VITE_DEFAULT_PAPER_BALANCE_USD=1000
BOT_QUOTE_ASSET=USDT
PAYMENT_CONVERT_BRL_TO_USD=true

APP_ENV=production
APP_URL=https://invcripto.netlify.app
