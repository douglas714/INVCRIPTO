# INV CRIPTO IA - EXEMPLO DE VARIAVEIS
# Copie para .env.local no seu computador e preencha com as chaves reais.
# NUNCA envie .env.local para o GitHub.

VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_PUBLIC_KEY_AQUI
VITE_APP_NAME=INV CRIPTO IA

# Variaveis somente para backend/functions/worker. NUNCA usar no frontend.
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_AQUI
SUPABASE_SECRET_KEY=SUA_SUPABASE_SECRET_KEY_AQUI

# Binance - preencher futuramente somente em ambiente seguro
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Pix - futuro
PIX_PROVIDER=
PIX_CLIENT_ID=
PIX_CLIENT_SECRET=
